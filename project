#include <stdio.h>

int main(void) {
    float number1;
    float number2;
    char operator;

    printf("Enter a number:\n");
    scanf("%f", &number1);
    printf("Enter another number \n");
    scanf("%f", &number2);
    printf("Enter operator: \n");
    scanf(" %c", &operator);
    switch (operator) {
        case '+':
            printf("The result is %f", number1 + number2);
            break;
        case '-':
            printf("The result is %f", number1 - number2);
            break;
        case '/':
            printf("The result is %f", number1 / number2);
            break;
        case '*':
            printf("The result is %f", number1 * number2);
            break;
    }
    return 0;
}
